<%- include('../partials/admin-header') %>
<header class="page-header">
  <div>
    <h1>Suporte</h1>
    <p>Solicitações recebidas pelo WhatsApp.</p>
  </div>
</header>

<section class="panel">
  <table>
    <thead><tr><th>Data</th><th>Contato</th><th>Perfil</th><th>Mensagem</th></tr></thead>
    <tbody>
      <% notes.forEach(note => { %>
        <tr>
          <td><%= new Date(note.created_at).toLocaleString('pt-BR') %></td>
          <td><strong><%= note.company_name || note.name || '-' %></strong><br><small><%= note.phone || '-' %></small></td>
          <td><%= note.role || '-' %></td>
          <td><%= note.note %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<%- include('../partials/admin-footer') %>
